# Shopify app credentials. The Shopify CLI injects these automatically during
# `npm run dev`; fill them in only for manual or production deployments
# (values are in your Partner dashboard after `shopify app config link`).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# OAuth scopes. Must match [access_scopes] in shopify.app.toml.
# read_products: product copy + metafields; read_translations: Translate & Adapt
# content; read_locales: published locales for variant URLs; read_orders:
# experiment metrics. The app never writes to products.
SCOPES=read_products,read_translations,read_locales,read_orders

# Anthropic API key — required for variant generation and the claim guard.
ANTHROPIC_API_KEY=

# Claude model used for generation and the claim guard.
PAGE_TAILOR_MODEL=claude-opus-4-8
